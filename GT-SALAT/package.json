{
  "name": "gt-salat",
  "version": "1.0.0",
  "description": "GT-SALAT — واجهة رسومية حديثة لتذكير الصلاة والأذكار (الجيل الجديد من GT-salat-dikr)",
  "main": "dist-electron/main.js",
  "author": {
    "name": "SalehGNUTUX",
    "url": "https://salehgnutux.github.io/gnutux/"
  },
  "license": "GPL-3.0",
  "homepage": "./",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && electron-builder",
    "build:appimage": "tsc -b && vite build && electron-builder --linux AppImage",
    "build:deb": "tsc -b && vite build && electron-builder --linux deb",
    "build:rpm": "tsc -b && vite build && electron-builder --linux rpm",
    "build:all": "tsc -b && vite build && electron-builder --linux AppImage deb rpm",
    "pack": "tsc -b && vite build && electron-builder --dir",
    "preview": "vite preview",
    "start": "electron .",
    "typecheck": "tsc -b --noEmit"
  },
  "dependencies": {
    "adhan": "^4.4.3",
    "electron-store": "^8.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "@vitejs/plugin-react": "^4.2.1",
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "typescript": "^5.4.3",
    "vite": "^5.2.6",
    "vite-plugin-electron": "^0.28.4",
    "vite-plugin-electron-renderer": "^0.14.5"
  },
  "build": {
    "appId": "io.github.salehgnutux.gt-salat",
    "productName": "GT-SALAT",
    "copyright": "Copyright © 2026 SalehGNUTUX",
    "asar": true,
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "resources",
        "to": ".",
        "filter": ["**/*"]
      }
    ],
    "linux": {
      "target": [
        { "target": "AppImage", "arch": ["x64"] },
        { "target": "deb", "arch": ["x64"] },
        { "target": "rpm", "arch": ["x64"] }
      ],
      "category": "Utility;Qt;",
      "icon": "build/icons",
      "desktop": {
        "Name": "GT-SALAT",
        "Name[ar]": "GT-SALAT ـ تذكير الصلاة والأذكار",
        "Comment": "Modern GUI for prayer times and dhikr reminders",
        "Comment[ar]": "واجهة حديثة لتذكير الصلاة وعرض الأذكار",
        "Keywords": "prayer;salat;dhikr;islam;adhan;muslim;",
        "StartupWMClass": "gt-salat"
      },
      "maintainer": "SalehGNUTUX <gnutux.arabic@gmail.com>",
      "vendor": "SalehGNUTUX"
    },
    "appImage": {
      "artifactName": "${productName}-${version}-${arch}.AppImage"
    },
    "deb": {
      "depends": ["libnotify4", "libgtk-3-0", "libasound2 | libasound2t64"],
      "artifactName": "${productName}_${version}_${arch}.deb"
    },
    "rpm": {
      "depends": ["libnotify", "gtk3"],
      "artifactName": "${productName}-${version}.${arch}.rpm"
    }
  }
}
